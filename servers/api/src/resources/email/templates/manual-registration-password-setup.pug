doctype html
html
  head
    title Set Up Your Password for Asia M&A and Business Collaboration Platform
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    style.
      @media only screen and (max-width: 600px) {
        table {
          width: 100% !important;
        }
      }
  body(style="font-family: Arial, sans-serif; margin: 0; padding: 0;")
    table(width="100%" border="0" cellpadding="0" cellspacing="0" bgcolor="#f4f4f4")
      tr
        td(align="center" valign="top")
          table(width="600" border="0" cellpadding="20" cellspacing="0" bgcolor="#ffffff")
            tr
              td(align="center")
                h1(style="font-size: 24px; margin-bottom: 20px;") Set Up Your Password for [Your Company Name]
            tr
              td(align="left")
                p Welcome to Asia M&A and Business Collaboration Platform, #{userName}!
                p An account has been created for you by our admin team with the following details:
                p
                  | - <strong>Username:</strong> #{userName}
                  br
                  | - <strong>Email:</strong> #{email}
                p To set up your password and complete your registration, please click the button below:
            tr
              td(align="center")
                table(border="0" cellpadding="0" cellspacing="0")
                  tr
                    td(bgcolor="#a4c761" style="padding: 12px 24px; margin: 20px auto;")
                      a(href="#{actionLink}" style="font-size: 16px; color: #ffffff; text-decoration: none;") Set Up Your Password
            tr
              td(align="left" style="font-size: 12px; font-style: italic;")
                span * 
                | This is an automated message. Please do not reply directly to this email.
            tr
              td(align="left")
                p(style="margin-top: 20px;") If you did not initiate this registration, please 
                  a(href="mailto:info@mp-asia.com" style="text-decoration: underline;") contact our support team
                  | .
